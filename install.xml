<?xml version="1.0" encoding="utf-8"?>
<modification>
	<name>DC Omnibus</name>
	<code>dc_omnibus</code>
	<version>1.0.3</version>
	<author>Paweł Nosko — Design Cart</author>
	<link>https://designcart.pl</link>

	<file path="catalog/controller/product/product.php">
		<operation>
			<search><![CDATA[$data['footer'] = $this->load->controller('common/footer');]]></search>
			<add position="before"><![CDATA[
			if ($this->config->get('module_dc_omnibus_status')) {
				require_once(DIR_SYSTEM . 'library/dc_omnibus/frontend.php');
				DcOmnibusFrontend::inject($this->registry, $data, (int)$this->request->get['product_id']);
			}

			]]></add>
		</operation>
	</file>

	<file path="catalog/view/theme/*/template/product/product.twig">
		<operation>
			<search><![CDATA[{{ footer }}]]></search>
			<add position="before"><![CDATA[
{% if dc_omnibus_config is defined %}
<script>window.dcOmnibusConfig = {{ dc_omnibus_config|json_encode|raw }};</script>
{% endif %}
]]></add>
		</operation>
	</file>
</modification>
